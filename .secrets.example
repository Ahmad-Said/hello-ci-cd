# Copy this file to .secrets and fill in real values for local testing with act.
#
# IMPORTANT — Never commit .secrets to git. It is listed in .gitignore.
#
# Each key here must also exist as a GitHub repository secret so the real
# CI/CD pipelines on GitHub Actions can read them:
#   Repository → Settings → Secrets and variables → Actions → New repository secret
#
# ──────────────────────────────────────────────────────────────────────────────
# Used by all workflows (on-pull-request, on-push-main, on-tag)
APP_ENV=staging

# Used by the Push-to-Main / deploy workflow (on-push-main.yml)
DEPLOY_API_KEY=your_deploy_api_key_here

# Used by the Release workflow (on-tag.yml)
RELEASE_TOKEN=your_release_token_here
